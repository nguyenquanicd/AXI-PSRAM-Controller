restore_session -level default

MasterSourceFile run_lint.tcl
#------------------------------------------------------------------------------
# Synopsys Lint Run Script
#------------------------------------------------------------------------------
# Project inputs
set FILELIST   $::env(QSPI_RTL)/filelist.f
set DEFINES    ""
set TOP_DESIGN m_vlsi_qspi_top
# Lint setup
set enable_lint true
[Info] In case any tcl command throwing error , last 10 suppressed messages for the command will be shown on console.
configure_lint_setup
configure_lint_tag_parameter \
  -tag W123 \
  -parameter HANDLE_LARGE_BUS \
  -value yes \
  -goal lint_rtl_enhanced
# Parse and elaborate
analyze \
  -format sverilog \
  -vcs "-f $FILELIST" \
  -define "$DEFINES -timescale=1ns/10ps +lint=TFIPC-L"
elaborate $TOP_DESIGN
