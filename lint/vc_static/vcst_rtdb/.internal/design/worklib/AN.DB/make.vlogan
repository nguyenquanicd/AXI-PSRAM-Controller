
VLOGAN	= vlogan
VLOGAN_OPT	= -kdb=common_elab -kdb=common_elab -kdb=common_elab -kdb=incopt -sverilog -skip_translate_body +define+SYNTHESIS+-timescale=1ns/10ps++lint=TFIPC-L -q -full64 -full64

all :		_VCSgd_CwygAd_1.db \
	_VCSgd_6wsa1b_1.db \
	_VCSgd_t0SLQ_1.db \
	_VCSgd_SwjmLb_1.db \
	_VCSgd_l92ttc_1.db \
	_VCSgd_BpVvGe_1.db \
	_VCSgd_buLCEe_1.db \
	_VCSgd_CkN1De_1.db \
	_VCSgd_NbFD_1.db \
	_VCSgd_UMUZQ_1.db \
	_VCSgd_rF7jYc_1.db \



