        </mxCell>
        <mxCell id="l4ck5KwHsPR3_lQ-5wV3-3" value="&lt;b&gt;Idle&lt;/b&gt;&lt;div style=&quot;text-align: left;&quot;&gt;SW can configures all CSR register, and configure to enable the csr_ctrl_en at the last.&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="-1310" y="-7.25" width="420" height="114.5" as="geometry" />
        </mxCell>
        <mxCell id="wkgWEofYSYEFC-zO9XyY-1" value="&lt;b&gt;Set_up&lt;/b&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Check the all &quot;req&quot; bits, if the csr_*_req and there is no remain items (FIFO read and write are empty), IP will set the csr_*_ack = 1&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="-1310" y="136" width="420" height="114.5" as="geometry" />
        </mxCell>
        <mxCell id="wkgWEofYSYEFC-zO9XyY-2" value="&lt;b&gt;Wait_trans&lt;/b&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;If csr_independent_req and ack == 1, IP will move to &quot;Ind_cmd&quot; state, unless IP wait transaction for read and write&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="-1310" y="285.75" width="420" height="114.5" as="geometry" />
        </mxCell>
        <mxCell id="wkgWEofYSYEFC-zO9XyY-3" value="&lt;b&gt;Ind_cmd&lt;/b&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;CS is change 1 - 0, reg_cnt_cmd counts down, command is sent to IOPAD, when the reg_cnt_cmd ==0, IP returns to &quot;set_up&quot; state&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="-1310" y="426" width="420" height="114.5" as="geometry" />
        </mxCell>
        <mxCell id="wkgWEofYSYEFC-zO9XyY-4" value="&lt;b&gt;Write/Read&lt;/b&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;set the corresponding register reg_in_write/reg_in_read, which are used to mode data from FIFO to IOPAD in write phase or shift data from IOPAD to internal register in read phase&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="-1310" y="566.5" width="420" height="114.5" as="geometry" />
        </mxCell>
        <mxCell id="wPwwBk1ClFTVDOgwY2_8-1" value="&lt;b&gt;Cmd&lt;/b&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;CS changes 1-0 and reg_cnt_cmd is set to csr value before this state. Cmd is sent out to IOPAD until the reg_cnt_cmd = 0&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="-1310" y="705.5" width="420" height="114.5" as="geometry" />
        </mxCell>
        <mxCell id="wPwwBk1ClFTVDOgwY2_8-2" value="&lt;b&gt;Addr&lt;/b&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;reg_cnt_addr is set to csr value before this state. Addr is sent out to IOPAD until the reg_cnt_addr = 0&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="-1310" y="844.75" width="420" height="114.5" as="geometry" />
        </mxCell>
        <mxCell id="wPwwBk1ClFTVDOgwY2_8-3" value="&lt;b&gt;Dummy&lt;/b&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;reg_cnt_dummy is set to csr value before this state.&amp;nbsp; the value of IOPAD will be dummy until the reg_cnt_dummy = 0&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="-1310" y="987.5" width="420" height="114.5" as="geometry" />
        </mxCell>
        <mxCell id="wPwwBk1ClFTVDOgwY2_8-4" value="&lt;b&gt;Data&lt;/b&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;reg_cnt_data is set to csr value before this state.&amp;nbsp; the data will shift out to IOPAD until the reg_cnt_data = 0&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="-1310" y="1127" width="420" height="114.5" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
