#------------------------------------------------------------------------------
# Synopsys CDC Run Script
#------------------------------------------------------------------------------
# Project inputs
set FILELIST   $::env(QSPI_FILELIST)
set DEFINES    ""
set TOP_DESIGN m_vlsi_qspi_top
# CDC setup
set enable_cdc true
configure_cdc_setup_check
# Parse and elaborate
analyze \
  -format sverilog \
  -vcs "-f $FILELIST" \
  -define "$DEFINES -timescale=1ns/10ps +lint=TFIPC-L"
